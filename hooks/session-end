#!/usr/bin/env bash
# Stop hook for ingram-office plugin
# Deterministic: commits and pushes any vault changes on session end

set -euo pipefail

IDENTITY_FILE="$HOME/.ingram-office/identity.json"

# Skip if not configured
[ ! -f "$IDENTITY_FILE" ] && exit 0

NAME=$(python3 -c "import json,sys; print(json.load(open(sys.argv[1]))['name'])" "$IDENTITY_FILE" 2>/dev/null || echo "")
VAULT=$(python3 -c "import json,sys; print(json.load(open(sys.argv[1]))['vault'])" "$IDENTITY_FILE" 2>/dev/null || echo "")

[ -z "$NAME" ] || [ -z "$VAULT" ] || [ ! -d "$VAULT" ] && exit 0

cd "$VAULT" || exit 0

# Check if there are any changes to commit
if git diff --quiet HEAD 2>/dev/null && [ -z "$(git ls-files --others --exclude-standard -- "team/$NAME/")" ]; then
  # No changes — nothing to do
  exit 0
fi

# Stage only the current user's folder and projects/
git add "team/$NAME/" 2>/dev/null || true
git add "projects/" 2>/dev/null || true

# Only commit if there are staged changes
if ! git diff --cached --quiet 2>/dev/null; then
  git commit -m "[$NAME] session end — auto-commit" 2>/dev/null || true
  git push 2>/dev/null || true
fi

exit 0
