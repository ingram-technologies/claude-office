#!/usr/bin/env bash
# Stop hook for ingram-office plugin
# Reads conversation transcript, logs prompts + changes to activity.md, commits locally

set -euo pipefail

IDENTITY_FILE="$HOME/.ingram-office/identity.json"

[ ! -f "$IDENTITY_FILE" ] && exit 0

parse_json() {
  local file="$1" key="$2"
  node -e "console.log(JSON.parse(require('fs').readFileSync('$file','utf8'))['$key'])" 2>/dev/null \
    || python3 -c "import json,sys; print(json.load(open(sys.argv[1]))['$key'])" "$file" 2>/dev/null \
    || echo ""
}

NAME=$(parse_json "$IDENTITY_FILE" "name")
VAULT=$(parse_json "$IDENTITY_FILE" "vault")

[ -z "$NAME" ] || [ -z "$VAULT" ] || [ ! -d "$VAULT" ] && exit 0

# Read Stop hook stdin for transcript_path
hook_input=$(cat)
transcript_path=""
if [ -n "$hook_input" ]; then
  transcript_path=$(echo "$hook_input" | node -e "
    let d=''; process.stdin.on('data',c=>d+=c); process.stdin.on('end',()=>{
      try { console.log(JSON.parse(d).transcript_path||''); } catch(e) { console.log(''); }
    });
  " 2>/dev/null || echo "")
fi

# Extract user prompts from transcript JSONL
prompts=""
if [ -n "$transcript_path" ] && [ -f "$transcript_path" ]; then
  prompts=$(node -e "
    const fs=require('fs'), lines=fs.readFileSync('$transcript_path','utf8').trim().split('\n');
    const msgs=[];
    for(const l of lines){
      try{
        const o=JSON.parse(l);
        if(o.type==='human'||o.role==='user'){
          let txt=typeof o.content==='string'?o.content:'';
          if(Array.isArray(o.content)) txt=o.content.filter(b=>b.type==='text').map(b=>b.text).join(' ');
          txt=txt.replace(/\\n/g,' ').trim();
          if(txt && txt.length>0 && txt.length<500) msgs.push(txt);
        }
      }catch(e){}
    }
    // Deduplicate and take up to 10 prompts
    const seen=new Set(); const unique=[];
    for(const m of msgs){ if(!seen.has(m)){seen.add(m);unique.push(m);} }
    unique.slice(0,10).forEach(m=>console.log('  - '+m));
  " 2>/dev/null || echo "")
fi

cd "$VAULT" || exit 0

# Collect what changed (unstaged + staged, excluding activity.md itself)
changed_files=$(git diff --name-only HEAD 2>/dev/null | grep -v "activity.md" || true)
untracked=$(git ls-files --others --exclude-standard 2>/dev/null | grep -v "activity.md" || true)
all_changes="$changed_files"
[ -n "$untracked" ] && all_changes="$all_changes
$untracked"

# Only log if there were actual doc changes or prompts to record
if [ -n "$all_changes" ] || [ -n "$prompts" ]; then
  activity_file="$VAULT/team/$NAME/activity.md"

  if [ -f "$activity_file" ]; then
    timestamp=$(date +"%Y-%m-%d %H:%M")

    # Extract project folders from changed paths
    projects=$(echo "$all_changes" | grep -oE 'projects/[^/]+' | sort -u | sed 's|projects/||' | tr '\n' ', ' | sed 's/,$//' || true)

    # Build concise file list (deduplicated basenames, max 10)
    total_files=0
    file_list=""
    if [ -n "$all_changes" ]; then
      total_files=$(echo "$all_changes" | wc -l | tr -d ' ')
      file_list=$(echo "$all_changes" | sed 's|.*/||' | sort -u | head -10 | tr '\n' ', ' | sed 's/,$//' || true)
      unique_count=$(echo "$all_changes" | sed 's|.*/||' | sort -u | wc -l | tr -d ' ')
      [ "$unique_count" -gt 10 ] && file_list="$file_list (+$((unique_count - 10)) more)"
    fi

    # Append entry
    {
      echo ""
      echo "## $timestamp"
      if [ -n "$prompts" ]; then
        echo "- Prompts:"
        echo "$prompts"
      fi
      [ -n "$file_list" ] && echo "- Files touched: $file_list ($total_files changes)"
      [ -n "$projects" ] && echo "- Projects: $projects"
    } >> "$activity_file"
  fi
fi

exit 0
