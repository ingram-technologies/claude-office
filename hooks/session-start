#!/usr/bin/env bash
# SessionStart hook for ingram-office plugin
# Pulls vault, injects identity + recent doc changes summary

set -euo pipefail

IDENTITY_FILE="$HOME/.ingram-office/identity.json"

if [ ! -f "$IDENTITY_FILE" ]; then
  context="<ingram-office-setup>\nIngram Office plugin is not configured. Run /setup-identity to set your name and vault path before using any commands.\n</ingram-office-setup>"
else
  parse_json() {
    local file="$1" key="$2"
    node -e "console.log(JSON.parse(require('fs').readFileSync('$file','utf8'))['$key'])" 2>/dev/null \
      || python3 -c "import json,sys; print(json.load(open(sys.argv[1]))['$key'])" "$file" 2>/dev/null \
      || echo ""
  }

  NAME=$(parse_json "$IDENTITY_FILE" "name")
  VAULT=$(parse_json "$IDENTITY_FILE" "vault")

  if [ -z "$NAME" ] || [ -z "$VAULT" ] || [ ! -d "$VAULT" ]; then
    context="<ingram-office-error>\nIdentity file exists but is invalid or vault path missing. Run /setup-identity to fix.\n</ingram-office-error>"
  else
    # Git pull
    if cd "$VAULT" 2>/dev/null; then
      git pull --rebase=false 2>/dev/null || true
    fi

    # Count recent changes (last 24h) by other people
    others_changed=0
    if cd "$VAULT" 2>/dev/null; then
      others_changed=$(git log --since="24 hours ago" --name-only --pretty=format:"%an" -- 'team/' 'projects/' 2>/dev/null | grep -v "^$" | head -50 | wc -l | tr -d ' ' || echo "0")
    fi

    # Check if personal task.md exists and has items
    task_file="$VAULT/team/$NAME/task.md"
    task_count=0
    if [ -f "$task_file" ]; then
      task_count=$(grep -cE '^\s*- \[ \]' "$task_file" 2>/dev/null || echo "0")
    fi

    # Build context
    summary="<ingram-office-session identity=\"$NAME\" vault=\"$VAULT\">"
    summary="$summary\nYou are working as **$NAME** in the Ingram Office vault at \`$VAULT\`."
    summary="$summary\nThis vault is a central documentation hub. Task tracking happens in GitHub."
    summary="$summary\nAvailable commands: /check-in, /aggregate, /retro, /setup-identity, /import-activity"
    summary="$summary\n**Vault awareness**: Use the \`vault-awareness\` skill to understand the vault structure and find relevant docs."

    [ "$task_count" -gt 0 ] && summary="$summary\n- **$task_count open todo(s)** in your task.md"
    [ "$others_changed" -gt 0 ] && summary="$summary\n- **Docs changed in last 24h** — run /check-in for details"

    summary="$summary\n</ingram-office-session>"
    context="$summary"
  fi
fi

# Output JSON
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

escaped=$(escape_for_json "$context")

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$escaped"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$escaped"
else
  printf '{\n  "additional_context": "%s"\n}\n' "$escaped"
fi

exit 0
