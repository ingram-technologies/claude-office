#!/usr/bin/env bash
# Stop hook for ingram-office plugin
# Deterministic: commits and pushes ONLY the current user's team folder

set -euo pipefail

IDENTITY_FILE="$HOME/.ingram-office/identity.json"

# Skip if not configured
[ ! -f "$IDENTITY_FILE" ] && exit 0

# Parse JSON with node falling back to python3
parse_json() {
  local file="$1" key="$2"
  node -e "console.log(JSON.parse(require('fs').readFileSync('$file','utf8'))['$key'])" 2>/dev/null \
    || python3 -c "import json,sys; print(json.load(open(sys.argv[1]))['$key'])" "$file" 2>/dev/null \
    || echo ""
}

NAME=$(parse_json "$IDENTITY_FILE" "name")
VAULT=$(parse_json "$IDENTITY_FILE" "vault")

[ -z "$NAME" ] || [ -z "$VAULT" ] || [ ! -d "$VAULT" ] && exit 0

cd "$VAULT" || exit 0

# Only stage the current user's folder — never projects/ or other people's folders
# projects/ is only committed by /aggregate, other people's inboxes are committed
# explicitly by /track-work when assigning tasks
git add "team/$NAME/" 2>/dev/null || true

# Only commit if there are staged changes
if ! git diff --cached --quiet 2>/dev/null; then
  git commit -m "[$NAME] session end — auto-commit" 2>/dev/null || true
  git push 2>/dev/null || true
fi

exit 0
