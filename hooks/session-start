#!/usr/bin/env bash
# SessionStart hook for ingram-office plugin
# Deterministic: reads identity, pulls vault, processes inbox, injects context

set -euo pipefail

IDENTITY_FILE="$HOME/.ingram-office/identity.json"

# --- 1. Read identity ---
if [ ! -f "$IDENTITY_FILE" ]; then
  # No identity configured — inject setup prompt
  context="<ingram-office-setup>\nIngram Office plugin is not configured. Run /setup-identity to set your name and vault path before using any commands.\n</ingram-office-setup>"
else
  NAME=$(python3 -c "import json,sys; print(json.load(open(sys.argv[1]))['name'])" "$IDENTITY_FILE" 2>/dev/null || echo "")
  VAULT=$(python3 -c "import json,sys; print(json.load(open(sys.argv[1]))['vault'])" "$IDENTITY_FILE" 2>/dev/null || echo "")

  if [ -z "$NAME" ] || [ -z "$VAULT" ] || [ ! -d "$VAULT" ]; then
    context="<ingram-office-error>\nIdentity file exists but is invalid or vault path missing. Run /setup-identity to fix.\n</ingram-office-error>"
  else
    # --- 2. Git pull the vault ---
    pull_result=""
    if cd "$VAULT" 2>/dev/null; then
      pull_result=$(git pull --rebase=false 2>&1 || echo "git pull failed")
    fi

    # --- 3. Read inbox ---
    inbox_file="$VAULT/team/$NAME/inbox.md"
    inbox_items=""
    inbox_count=0
    if [ -f "$inbox_file" ]; then
      # Count non-empty, non-comment, non-header lines that start with "- ["
      inbox_items=$(grep -E '^\s*- \[' "$inbox_file" 2>/dev/null || true)
      if [ -n "$inbox_items" ]; then
        inbox_count=$(echo "$inbox_items" | wc -l | tr -d ' ')
      fi
    fi

    # --- 4. Read priority tasks ---
    tasks_file="$VAULT/team/$NAME/tasks.md"
    p0_p1=""
    overdue=""
    today=$(date +%Y-%m-%d)
    if [ -f "$tasks_file" ]; then
      p0_p1=$(grep -E '#P[01]\b' "$tasks_file" 2>/dev/null | grep -v '^\s*- \[x\]' | head -10 || true)
      # Find overdue: tasks with due:: date before today that aren't completed
      overdue=$(grep -E '\(due::' "$tasks_file" 2>/dev/null | grep -v '^\s*- \[x\]' | while IFS= read -r line; do
        due_date=$(echo "$line" | grep -oP '\(due::\s*\K[0-9-]+' || true)
        if [ -n "$due_date" ] && [[ "$due_date" < "$today" ]]; then
          echo "$line"
        fi
      done | head -5 || true)
    fi

    # --- 5. Build context ---
    summary="<ingram-office-session identity=\"$NAME\" vault=\"$VAULT\">"
    summary="$summary\nYou are working as **$NAME** in the Ingram Office vault at \`$VAULT\`."
    summary="$summary\nAvailable commands: /check-in, /track-work, /aggregate, /retro, /setup-identity"

    if [ "$inbox_count" -gt 0 ]; then
      summary="$summary\n\n**New assignments in inbox ($inbox_count):**\n$inbox_items"
    fi

    if [ -n "$overdue" ]; then
      summary="$summary\n\n**Overdue tasks:**\n$overdue"
    fi

    if [ -n "$p0_p1" ]; then
      summary="$summary\n\n**High priority (P0/P1):**\n$p0_p1"
    fi

    if [ "$inbox_count" -eq 0 ] && [ -z "$p0_p1" ] && [ -z "$overdue" ]; then
      summary="$summary\nNo urgent items."
    fi

    summary="$summary\n</ingram-office-session>"
    context="$summary"
  fi
fi

# --- Output JSON ---
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

escaped=$(escape_for_json "$context")

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$escaped"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$escaped"
else
  printf '{\n  "additional_context": "%s"\n}\n' "$escaped"
fi

exit 0
